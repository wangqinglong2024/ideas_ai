# syntax=docker/dockerfile:1.7

# ===== deps + build =====
FROM node:20-alpine AS build
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@9.12.0 --activate
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* .npmrc tsconfig.base.json ./
COPY packages ./packages
COPY apps/web ./apps/web
COPY apps/api/package.json apps/api/
COPY apps/admin-api/package.json apps/admin-api/
COPY apps/worker/package.json apps/worker/
COPY apps/admin/package.json apps/admin/
RUN pnpm install --filter "@zhiyu/web..." --no-frozen-lockfile

ARG VITE_API_BASE
ARG VITE_SUPABASE_URL
ARG VITE_SUPABASE_ANON_KEY
ENV VITE_API_BASE=${VITE_API_BASE}
ENV VITE_SUPABASE_URL=${VITE_SUPABASE_URL}
ENV VITE_SUPABASE_ANON_KEY=${VITE_SUPABASE_ANON_KEY}
RUN pnpm --filter @zhiyu/web build

# ===== runtime: nginx static =====
FROM nginx:1.27-alpine AS runtime
RUN addgroup -S app 2>/dev/null || true
COPY --from=build /app/apps/web/dist /usr/share/nginx/html
COPY docker/nginx.spa.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
HEALTHCHECK --interval=15s --timeout=3s --retries=4 \
  CMD wget -qO- http://127.0.0.1/healthz >/dev/null || exit 1
CMD ["nginx", "-g", "daemon off;"]

# ===== dev (hot-reload via vite) =====
FROM node:20-alpine AS dev
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@9.12.0 --activate
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* .npmrc tsconfig.base.json ./
COPY packages ./packages
COPY apps/web ./apps/web
COPY apps/api/package.json apps/api/
COPY apps/admin-api/package.json apps/admin-api/
COPY apps/worker/package.json apps/worker/
COPY apps/admin/package.json apps/admin/
RUN pnpm install --filter "@zhiyu/web..." --no-frozen-lockfile
WORKDIR /app/apps/web
EXPOSE 5173
CMD ["pnpm", "dev"]
