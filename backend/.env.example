# =========================================
# Supabase
# =========================================
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
SUPABASE_JWT_SECRET=your-jwt-secret

# =========================================
# Admin 认证（独立，与 Supabase 完全隔离）
# =========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$...
ADMIN_JWT_SECRET=another-random-secret-min-32chars

# =========================================
# 微信支付
# =========================================
WECHAT_PAY_MCHID=1234567890
WECHAT_PAY_APPID=wx1234567890abcdef
WECHAT_PAY_API_V3_KEY=your-32char-key
WECHAT_PAY_SERIAL_NO=xxxxx
WECHAT_PAY_PRIVATE_KEY_PATH=/app/certs/apiclient_key.pem

# =========================================
# 支付宝
# =========================================
ALIPAY_APP_ID=2021xxxxxxxx
ALIPAY_PRIVATE_KEY=MIIEow...
ALIPAY_PUBLIC_KEY=MIIBIjAN...

# =========================================
# 短信服务
# =========================================
SMS_PROVIDER=aliyun
ALIYUN_ACCESS_KEY_ID=LTAI5t...
ALIYUN_ACCESS_KEY_SECRET=xxxx
ALIYUN_SMS_SIGN_NAME=内观
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxx

# =========================================
# Dify AI
# =========================================
DIFY_API_URL=https://api.dify.ai/v1
DIFY_API_KEY=app-xxxxxxxxxxxx
DIFY_WORKFLOW_TIMEOUT=60

# =========================================
# 应用配置
# =========================================
APP_ENV=production
APP_BASE_URL=https://ideas.top
WECHAT_PAY_NOTIFY_URL=https://ideas.top/api/webhooks/wechat-pay
ALIPAY_NOTIFY_URL=https://ideas.top/api/webhooks/alipay
ALIPAY_RETURN_URL=https://ideas.top/paying/{order_id}
